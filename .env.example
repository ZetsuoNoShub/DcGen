# ── Discord ──────────────────────────────────────────────────────────────────
# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL and service role key
# Found at: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ── Discord IDs ───────────────────────────────────────────────────────────────
# Channel where .gen commands are accepted
GEN_CHANNEL_ID=your_gen_channel_id

# Role required to use staff commands (.link, .tv, .send, etc.)
STAFF_ROLE_ID=your_staff_role_id

# Role IDs for tier access
ROLE_BOOSTER=your_booster_role_id
ROLE_PREMIUM=your_premium_role_id
ROLE_GOD=your_god_role_id

# ── Site ──────────────────────────────────────────────────────────────────────
# URL of your frontend (used for redirect links sent to users)
SITE_URL=https://your-site.vercel.app

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Password for the web control panel (control.html)
ADMIN_PASSWORD=change_this_to_something_strong
